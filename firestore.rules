rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /researchhq/main {
      // Anyone can read (public visibility)
      allow read: if true;
      // Only the authorized editor can write
      allow write: if request.auth != null
                   && request.auth.token.email == 'zecalanga12@gmail.com';
    }
  }
}
